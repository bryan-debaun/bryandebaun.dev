{
  "name": "bryandebaun.dev",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "contentlayer2",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "content:dev": "contentlayer2 dev",
    "run-content": "tsx scripts/run-content.ts",
    "normalize-content": "tsx scripts/run-content.ts --apply-normalize",
    "build:packages": "tsc --build packages/mcp-client",
    "build": "pnpm run build:packages && pnpm exec tsx scripts/build.ts",
    "generate:mcp-client": "tsx scripts/generate-mcp-client.ts",
    "associate:admin": "tsx scripts/associate-admin.ts",
    "verify:mcp-client": "tsx scripts/generate-mcp-client.ts && git --no-pager diff --exit-code packages/mcp-client/src || (echo 'Generated client out-of-date; run pnpm run generate:mcp-client' && exit 1)",
    "test:content": "tsx scripts/check-content.ts",
    "content:checks": "pnpm run verify:icons && pnpm run verify:no-omega && pnpm run lint:content && pnpm run cspell:check && pnpm run link-check",
    "lint:content": "remark \"README.md\" \"docs/**/*.md\" -q",
    "cspell:check": "cspell \"README.md\" \"docs/**/*..md\" \"src/content/**/*.{md,mdx}\"",
    "link-check": "markdown-link-check -c .markdown-link-check.json \"README.md\"",
    "verify:icons": "tsx scripts/verify-manifest-icons.ts",
    "verify:no-omega": "tsx scripts/verify-no-omega.ts",
    "verify:local": "pnpm run run-content && pnpm run test:content && pnpm run content:checks && pnpm run build && pnpm run lint",
    "icons:generate": "tsx scripts/generate-icons.ts --src public/icons/wolf.svg --out public/icons --sizes 16,32,48,96,180,192,512",
    "lint:biome": "biome check src",
    "lint:biome:fix": "biome check src --write",
    "test": "vitest --run",
    "start": "next start",
    "resume:pdf": "tsx scripts/generate-resume-pdf.ts",
    "a11y:local": "tsx scripts/a11y/verify-a11y.ts --url http://localhost:3000 --outDir artifacts/a11y",
    "a11y:ci": "tsx scripts/a11y/verify-a11y.ts --url http://localhost:3000 --outDir artifacts/a11y --ci",
    "playwright:install": "pnpm exec playwright install --with-deps",
    "visual:test": "pnpm exec playwright test --config=playwright.config.ts",
    "visual:baseline": "tsx scripts/generate-visual-baseline.ts",
    "inspect:ci": "tsx scripts/inspect-diff-ci-run.ts",
    "ci:lighthouse": "lhci autorun",
    "lint:mdx": "node -e \"const glob=require('glob'); const files=glob.sync('src/content/**/*.{md,mdx}'); if(!files.length){console.log('No MDX files to lint (none or all ignored)'); process.exit(0);} const cp=require('child_process').spawnSync('eslint',['--ext','.mdx','src/content/**/*.{md,mdx}'],{stdio:'inherit'}); process.exit(cp.status);\"",
    "lint": "eslint"
  },
  "vitest": {
    "globals": true,
    "test": {
      "environment": "jsdom",
      "threads": false,
      "setupFiles": [
        "src/setupTests.ts"
      ],
      "exclude": [
        "tests/visual/**"
      ]
    }
  },
  "dependencies": {
    "@bryandebaun/mcp-client": "workspace:*",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.13.4",
    "next": "16.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@contentlayer/source-files": "^0.3.4",
    "@fontsource/inter": "^4.5.12",
    "@mdx-js/mdx": "^3.1.1",
    "@opentelemetry/api": "^1.9.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/forms": "^0.5.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axe-core": "^4.11.1",
    "chrome-launcher": "^1.2.1",
    "contentlayer2": "^0.4.5",
    "cspell": "^9.6.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "eslint-mdx": "^3.6.2",
    "eslint-plugin-mdx": "^3.6.2",
    "eslint-plugin-node": "^11.1.0",
    "jsdom": "^27.4.0",
    "lighthouse": "^11.0.0",
    "markdown-link-check": "^3.14.2",
    "pixelmatch": "^5.3.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.6",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^4.0.1",
    "remark-lint": "^10.0.1",
    "remark-mdx": "^3.1.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "remark-preset-lint-recommended": "^7.0.1",
    "rimraf": "^5.0.0",
    "sharp": "^0.34.5",
    "swagger-typescript-api": "^13.2.16",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.18.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0"
  }
}
